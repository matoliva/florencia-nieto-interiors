---
import { Font } from "astro:assets";
import Sidebar from "../components/Sidebar.astro";
import MobileHeader from "../components/MobileHeader.astro";
import "../styles/global.css";

const lang = Astro.currentLocale ?? 'en';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Florencia Nieto</title>
		<Font cssVariable="--font-andarilho" />
		<Font cssVariable="--font-leelawadee" />
		<Font cssVariable="--font-castorgate" />
		<Font cssVariable="--font-avenir" />
	</head>
	<body>
		<div class="flex h-full">
			<div class="hidden md:block shrink-0">
				<Sidebar />
			</div>
			<div id="page-scroll" class="flex-1 min-w-0 flex flex-col overflow-y-auto scroll-smooth [container-type:inline-size]">
				<div class="sticky top-0 z-40 block md:hidden">
					<MobileHeader />
				</div>
				<main class="pb-16 md:pb-24 max-w-[1600px] mx-auto w-full">
					<slot />
				</main>
			</div>
		</div>
	</body>
	<script is:inline>
		(function () {
			function setHeaderHeight() {
				var h = document.querySelector('header');
				if (h) document.documentElement.style.setProperty('--mobile-header-h', h.offsetHeight + 'px');
			}
			setHeaderHeight();
			window.addEventListener('resize', setHeaderHeight);

			// The scrollable container is #page-scroll (body is overflow:hidden),
			// so the browser cannot save or restore scroll position correctly.
			// We take over entirely.
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}

			function scrollToHash() {
				var hash = window.location.hash;
				if (!hash) return;
				var el = document.querySelector(hash);
				if (el) el.scrollIntoView({ behavior: 'smooth' });
			}

			// Same-page hash changes (back/forward within the same page)
			window.addEventListener('popstate', scrollToHash);

			// Full page loads and bfcache restores (covers browser back from another page)
			window.addEventListener('pageshow', scrollToHash);
		})();
	</script>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	body {
		overflow: hidden;
		background-color: var(--color-surface-primary);
		font-variant-emoji: text;
	}
	@media (max-width: 767px) {
		#page-scroll {
			scroll-padding-top: var(--mobile-header-h, 64px);
		}
	}
</style>
