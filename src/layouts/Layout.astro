---
import { Font } from "astro:assets";
import Sidebar from "../components/Sidebar.astro";
import MobileHeader from "../components/MobileHeader.astro";
import "../styles/global.css";

const lang = Astro.currentLocale ?? 'en';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Florencia Nieto</title>
		<Font cssVariable="--font-andarilho" />
		<Font cssVariable="--font-leelawadee" />
		<Font cssVariable="--font-castorgate" />
		<Font cssVariable="--font-avenir" />
	</head>
	<body>
		<div class="hidden md:block">
			<Sidebar />
		</div>
		<div class="block md:hidden">
			<MobileHeader />
		</div>
		<main class="w-full md:ml-60">
			<slot />
		</main>
	</body>
	<script is:inline>
		(function () {
			function setHeaderHeight() {
				var h = document.querySelector('header');
				if (h) document.documentElement.style.setProperty('--mobile-header-h', h.offsetHeight + 'px');
			}
			setHeaderHeight();
			window.addEventListener('resize', setHeaderHeight);
		})();
	</script>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
