---
import Layout from '../../layouts/Layout.astro';
import AboutHero from '../../components/AboutHero.astro';
import AboutDescription from '../../components/AboutDescription.astro';
import Divider from '../../components/Divider.astro';
import Section from '../../components/Section.astro';
import Quote from '../../components/Quote.astro';
import Button from '../../components/Button.astro';
import { useTranslations } from '../../i18n/utils';
import { personSchema, businessSchema } from '../../utils/schema';

const t = useTranslations(Astro.currentLocale);
---

<Layout
  title={t('seo.about.title')}
  description={t('seo.about.description')}
  type="profile"
  jsonLd={[personSchema(), businessSchema()]}
>
  <AboutHero name={t('about.hero.name')} subtitle={t('about.hero.subtitle')} />
  <Divider />
  <AboutDescription
    p1={t('about.description.p1')}
    p2={t('about.description.p2')}
    p3={t('about.description.p3')}
    p4={t('about.description.p4')}
    p5={t('about.description.p5')}
  />
  <Divider />
  <Section>
    <Quote quote={t('about.quote')} />
  </Section>
  <Divider />
  <Section class="text-center">
    <Button variant="outlined" label={t('services.cta.label')} href={t('services.cta.href')} />
  </Section>
</Layout>
