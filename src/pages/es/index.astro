---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Quote from '../../components/Quote.astro';
import Section from '../../components/Section.astro';
import CuratedProjects from '../../components/CuratedProjects.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import ContactSection from '../../components/ContactSection.astro';
import Divider from '../../components/Divider.astro';
import { useTranslations } from '../../i18n/utils';
import { projects } from '../../data/projects';
import { businessSchema } from '../../utils/schema';

const t = useTranslations(Astro.currentLocale);
const p1 = projects.find(p => p.slug === 'bold-gathering')!;
const p2 = projects.find(p => p.slug === 'timeless-home')!;
---
<Layout title={t('seo.home.title')} description={t('seo.home.description')} jsonLd={businessSchema()}>
  <Hero line1={t('home.hero.line1')} line2={t('home.hero.line2')} />
  <Section noPaddingBottom>
    <Quote quote={t('home.quote')} />
  </Section>
  <Divider />
  <CuratedProjects
    title={t('home.curatedProjects.title')}
    seeAllLabel={t('home.curatedProjects.seeAll')}
    seeAllHref={t('home.curatedProjects.seeAllHref')}
    project1Name={t('home.curatedProjects.project1Name')}
    project2Name={t('home.curatedProjects.project2Name')}
    project1Cover={p1.cover}
    project2Cover={p2.cover}
    project1Slug={p1.slug}
    project2Slug={p2.slug}
  />
  <Divider />
  <ServicesSection
    title={t('home.services.title')}
    subtitle={t('home.services.subtitle')}
    service1Numeral={t('home.services.service1.numeral')}
    service1Title={t('home.services.service1.title')}
    service1Description={t('home.services.service1.description')}
    service1Href={t('home.services.service1.href')}
    service2Numeral={t('home.services.service2.numeral')}
    service2Title={t('home.services.service2.title')}
    service2Description={t('home.services.service2.description')}
    service2Href={t('home.services.service2.href')}
    service3Numeral={t('home.services.service3.numeral')}
    service3Title={t('home.services.service3.title')}
    service3Description={t('home.services.service3.description')}
    service3Href={t('home.services.service3.href')}
    knowMoreLabel={t('home.services.knowMore')}
  />
  <Divider />
  <ContactSection />
</Layout>
