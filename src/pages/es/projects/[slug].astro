---
import Layout from '../../../layouts/Layout.astro';
import ProjectDetailHero from '../../../components/ProjectDetailHero.astro';
import ProjectGallery from '../../../components/ProjectGallery.astro';
import Divider from '../../../components/Divider.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';
import { projects } from '../../../data/projects';
import { useTranslations } from '../../../i18n/utils';
import { projectSchema, breadcrumbSchema } from '../../../utils/schema';
import { getOptimizedCloudinaryUrl } from '../../../utils/cloudinary';

export const prerender = true;

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const t = useTranslations(Astro.currentLocale);

const projectUrl = `/es/projects/${project.slug}`;
const ogImage = getOptimizedCloudinaryUrl(project.cover, { width: 1200 });
const jsonLd = [
  projectSchema({
    name: project.name,
    description: project.descriptionEs,
    url: projectUrl,
    images: project.imageGallery.slice(0, 6),
  }),
  breadcrumbSchema([
    { name: 'Inicio', url: '/es' },
    { name: 'Proyectos', url: '/es/projects' },
    { name: project.name, url: projectUrl },
  ]),
];
---

<Layout
  title={`${project.name}${t('seo.project.titleSuffix')}`}
  description={project.descriptionEs}
  image={ogImage}
  type="article"
  jsonLd={jsonLd}
>
  <ProjectDetailHero
    name={project.name}
    description={project.descriptionEs}
    headerImage={project.headerImage}
  />
  <Divider />
  <ProjectGallery images={project.imageGallery} name={project.name} />
  <Divider />
  <Section class="text-center">
    <Button variant="outlined" label={t('services.cta.label')} href={t('services.cta.href')} />
  </Section>
</Layout>
