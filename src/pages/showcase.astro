---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import InlineLink from '../components/InlineLink.astro';
import ExternalLink from '../components/ExternalLink.astro';
import NavLink from '../components/NavLink.astro';
import Heading from '../components/Heading.astro';
import Body from '../components/Body.astro';
import Section from '../components/Section.astro';
import FormInput from '../components/FormInput.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<Layout title={t('showcase.title')}>
  <main class="min-h-screen bg-surface-primary">
  <Section>
    <div class="max-w-sm border border-border-default p-10">

      <h2 class="font-body uppercase tracking-widest text-xs text-text-display mb-3">
        {t('showcase.section.buttons')}
      </h2>
      <div class="border-t border-border-default mb-12"></div>

      <div class="flex flex-col gap-12">

        <div>
          <Button variant="arrow" label={t('showcase.button.knowMore')} href="#" />
        </div>

        <div>
          <Button variant="download" label={t('showcase.button.downloadPortfolio')} href="#" />
        </div>

        <div>
          <Button variant="outlined" label={t('showcase.button.howItWorks')} href="#" />
        </div>

        <div>
          <p class="font-body uppercase tracking-widest text-xs text-text-display">
            {t('showcase.inlineLink.prefix')}&nbsp;<InlineLink href="#">{t('showcase.inlineLink.label')}</InlineLink>
          </p>
        </div>

      </div>
    </div>

    <div class="max-w-2xl border border-border-default p-10 mt-8">

      <h2 class="font-body uppercase tracking-widest text-xs text-text-display mb-3">
        {t('showcase.section.typography')}
      </h2>
      <div class="border-t border-border-default mb-12"></div>

      <div class="flex flex-col gap-12">

        <div>
          <p class="font-body uppercase tracking-widest text-xs text-text-tertiary mb-3">Display · Hero — Leelawadee UI</p>
          <Heading variant="hero">Florencia Nieto</Heading>
        </div>

        <div>
          <p class="font-body uppercase tracking-widest text-xs text-text-tertiary mb-3">Display · Page H1 — Leelawadee UI</p>
          <Heading variant="h1">Interior Design</Heading>
        </div>

        <div>
          <p class="font-body uppercase tracking-widest text-xs text-text-tertiary mb-3">Editorial · H2 — Castorgate</p>
          <Heading variant="h2">Selected Projects</Heading>
        </div>

        <div>
          <p class="font-body uppercase tracking-widest text-xs text-text-tertiary mb-3">Body — Avenir</p>
          <Body class="max-w-prose">We create spaces that reflect who you are — warm, considered, and built to last. Each project begins with listening.</Body>
        </div>

      </div>
    </div>

    <div class="max-w-sm border border-border-default p-10 mt-8">

      <h2 class="font-body uppercase tracking-widest text-xs text-text-display mb-3">
        {t('showcase.section.links')}
      </h2>
      <div class="border-t border-border-default mb-12"></div>

      <div class="flex flex-col gap-12">

        <div>
          <ExternalLink label={t('showcase.externalLink.instagram')} href="#" />
        </div>

        <div class="flex flex-col gap-8">
          <NavLink label={t('showcase.navLink.about')} href="#" />
          <NavLink label={t('showcase.navLink.selectedProjects')} href="#" />
          <NavLink label={t('showcase.navLink.services')} href="#" />
          <NavLink label={t('showcase.navLink.shop')} href="#" />
          <NavLink label={t('showcase.navLink.contact')} href="#" active />
        </div>

      </div>
    </div>
    <div class="max-w-sm border border-border-default p-10 mt-8">

      <h2 class="font-body uppercase tracking-widest text-xs text-text-display mb-3">
        {t('showcase.section.formInputs')}
      </h2>
      <div class="border-t border-border-default mb-12"></div>

      <div class="flex flex-col gap-10">

        <FormInput
          label="First Name"
          name="first_name"
          placeholder="Florencia"
        />

        <FormInput
          label="Email"
          name="email"
          type="email"
          placeholder="florencia@example.com"
          required
        />

      </div>
    </div>
  </Section>
  </main>
</Layout>
