---
import Section from './Section.astro';
import Body from './Body.astro';

interface Props {
  p1: string;
  p2: string;
  p3: string;
  p4: string;
  p5: string;
}

const { p1, p2, p3, p4, p5 } = Astro.props;
---

<Section>
  <div>
    <Body>{p1}</Body>
    <Body class="mt-6">{p2}</Body>
    <Body class="mt-6">{p3}</Body>
    <Body class="mt-6">{p4}</Body>
    <Body class="mt-6">{p5}</Body>
  </div>
</Section>
