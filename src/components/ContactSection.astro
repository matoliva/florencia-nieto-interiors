---
import Section from './Section.astro';
import ContactForm from './ContactForm.tsx';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);

const translations = {
  firstName:            t('home.contact.firstName'),
  lastName:             t('home.contact.lastName'),
  email:                t('home.contact.email'),
  phone:                t('home.contact.phone'),
  projectAddress:       t('home.contact.projectAddress'),
  message:              t('home.contact.message'),
  preferredContact:     t('home.contact.preferredContact'),
  preferredContactEmail: t('home.contact.preferredContact.email'),
  preferredContactPhone: t('home.contact.preferredContact.phone'),
  source:               t('home.contact.source'),
  sourceReferral:       t('home.contact.source.referral'),
  sourceGoogle:         t('home.contact.source.google'),
  sourceInstagram:      t('home.contact.source.instagram'),
  sourceArchipro:       t('home.contact.source.archipro'),
  sourceLinkedin:       t('home.contact.source.linkedin'),
  sourceOther:          t('home.contact.source.other'),
  submit:               t('home.contact.submit'),
  submitting:           t('home.contact.submitting'),
  successTitle:         t('home.contact.success.title'),
  successMessage:       t('home.contact.success.message'),
  error:                t('home.contact.error'),
};
---

<Section id="contact" title={t('home.contact.title')}>
  <ContactForm client:load translations={translations} />
</Section>
