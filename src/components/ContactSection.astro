---
import Section from './Section.astro';
import ContactForm from './ContactForm.tsx';
import { useTranslations } from '../i18n/utils';
import { socialLinks } from '../config/nav';

const t = useTranslations(Astro.currentLocale);

const translations = {
  firstName:            t('home.contact.firstName'),
  lastName:             t('home.contact.lastName'),
  email:                t('home.contact.email'),
  phone:                t('home.contact.phone'),
  projectAddress:       t('home.contact.projectAddress'),
  message:              t('home.contact.message'),
  preferredContact:     t('home.contact.preferredContact'),
  preferredContactEmail: t('home.contact.preferredContact.email'),
  preferredContactPhone: t('home.contact.preferredContact.phone'),
  source:               t('home.contact.source'),
  sourceReferral:       t('home.contact.source.referral'),
  sourceGoogle:         t('home.contact.source.google'),
  sourceInstagram:      t('home.contact.source.instagram'),
  sourceArchipro:       t('home.contact.source.archipro'),
  sourceLinkedin:       t('home.contact.source.linkedin'),
  sourceOther:          t('home.contact.source.other'),
  submit:               t('home.contact.submit'),
  submitting:           t('home.contact.submitting'),
  successTitle:         t('home.contact.success.title'),
  successMessage:       t('home.contact.success.message'),
  error:                t('home.contact.error'),
  errorFirstName:       t('home.contact.error.firstName'),
  errorLastName:        t('home.contact.error.lastName'),
  errorEmail:           t('home.contact.error.email'),
  errorEmailInvalid:    t('home.contact.error.emailInvalid'),
};

const email = 'florencianieto.interiors@gmail.com';
const phone = t('home.contact.info.phoneValue');

const socials = [
  {
    href: socialLinks.find(l => l.key === 'social.instagram')!.href,
    handle: '@florencianieto.interiors',
    icon: 'instagram',
  },
  {
    href: socialLinks.find(l => l.key === 'social.linkedin')!.href,
    handle: 'florencianieto',
    icon: 'linkedin',
  },
  {
    href: socialLinks.find(l => l.key === 'social.houzz')!.href,
    handle: 'florencianieto87',
    icon: 'houzz',
  },
];
---

<Section id="contact" title={t('home.contact.title')}>
  <div class="grid grid-cols-1 lg:grid-cols-[3fr_7fr] gap-12 lg:gap-16">

    <!-- Left: contact info -->
    <div class="flex flex-col gap-4 lg:pt-2">
      <p class="text-body text-text-secondary mb-2">{t('home.contact.info.description')}</p>

      <!-- Email -->
      <a
        href={`mailto:${email}`}
        class="group flex items-center gap-3 text-body transition-colors duration-200 hover:text-accent-gold"
      >
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M2 7l10 7 10-7"/>
        </svg>
        {email}
      </a>

      <!-- Phone -->
      <div class="flex items-center gap-3 text-body text-text-tertiary">
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.9 12.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.82 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8 9.9a16 16 0 0 0 5.9 5.9l1.27-1.07a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phone}
      </div>

      <!-- Divider -->
      <div class="border-t border-border-default my-1"></div>

      <!-- Socials -->
      {socials.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-body transition-colors duration-200 hover:text-accent-gold"
        >
          {s.icon === 'instagram' && (
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          )}
          {s.icon === 'linkedin' && (
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          )}
          {s.icon === 'houzz' && (
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          )}
          <span>{s.handle}</span>
          <span aria-hidden="true" class="text-xs transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
        </a>
      ))}
    </div>

    <!-- Right: form -->
    <ContactForm client:load translations={translations} />

  </div>
</Section>
