---
import { Image } from 'astro:assets';
import img1 from '../assets/images/hero.jpg';
import img2 from '../assets/images/texture.jpg';
import Section from './Section.astro';
import Body from './Body.astro';
import Button from './Button.astro';

interface Props {
  title: string;
  seeAllLabel: string;
  seeAllHref: string;
  project1Name: string;
  project2Name: string;
  noPaddingTop?: boolean;
}

const { title, seeAllLabel, seeAllHref, project1Name, project2Name, noPaddingTop } = Astro.props;
---

<Section title={title} noPaddingTop={noPaddingTop}>
  <div class="flex flex-col gap-4 md:flex-row md:h-[480px]">
    <div class="relative flex-[3] h-56 md:h-full overflow-hidden group">
      <Image
        src={img1}
        alt={project1Name}
        class="w-full h-full object-cover object-center"
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 800px"
      />
      <div class="absolute inset-x-0 bottom-0 bg-black/40 px-5 py-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <Body as="span" class="text-white">{project1Name}</Body>
      </div>
    </div>

    <div class="relative flex-[2] h-72 md:h-full overflow-hidden group">
      <Image
        src={img2}
        alt={project2Name}
        class="w-full h-full object-cover object-center"
        widths={[400, 600]}
        sizes="(max-width: 768px) 100vw, 600px"
      />
      <div class="absolute inset-x-0 bottom-0 bg-black/40 px-5 py-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <Body as="span" class="text-white">{project2Name}</Body>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-end">
    <Button variant="arrow" label={seeAllLabel} href={seeAllHref} />
  </div>
</Section>
