---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import Heading from './Heading.astro';
import Body from './Body.astro';
import Button from './Button.astro';
import service1Img from '../assets/images/service-1.webp';
import service2Img from '../assets/images/service-2.webp';
import service3Img from '../assets/images/service-3.webp';

interface Props {
  title: string;
  subtitle: string;
  service1Numeral: string;
  service1Title: string;
  service1Description: string;
  service1Href: string;
  service2Numeral: string;
  service2Title: string;
  service2Description: string;
  service2Href: string;
  service3Numeral: string;
  service3Title: string;
  service3Description: string;
  service3Href: string;
  knowMoreLabel: string;
}

const {
  title, subtitle,
  service1Numeral, service1Title, service1Description, service1Href,
  service2Numeral, service2Title, service2Description, service2Href,
  service3Numeral, service3Title, service3Description, service3Href,
  knowMoreLabel,
} = Astro.props;

const services = [
  { numeral: service1Numeral, title: service1Title, description: service1Description, href: service1Href, image: service1Img },
  { numeral: service2Numeral, title: service2Title, description: service2Description, href: service2Href, image: service2Img },
  { numeral: service3Numeral, title: service3Title, description: service3Description, href: service3Href, image: service3Img },
];
---

<Section id="services" title={title} subtitle={subtitle}>
  <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border-default">
    {services.map((service, i) => (
      <div class:list={[
        'flex flex-col py-10 md:py-0',
        'md:px-6 lg:px-8',
      ]}>

        <!-- Service image -->
        <div class="h-40 md:h-44 lg:h-52 mb-8 overflow-hidden">
          <Image
            src={service.image}
            alt={service.title}
            class="w-full h-full object-contain"
            widths={[400, 700]}
            sizes="(min-width: 768px) 33vw, 100vw"
          />
        </div>

        <!-- Service numeral -->
        <p class="font-body uppercase tracking-widest text-xs text-accent-gold mb-5">
          {service.numeral}
        </p>

        <!-- Service title -->
        <Heading variant="h2" class="mb-6">{service.title}</Heading>

        <!-- Description -->
        <Body class="text-text-secondary flex-1 mb-10">{service.description}</Body>

        <!-- Know More button -->
        <div class="pb-8 md:pb-0">
          <Button variant="arrow" label={knowMoreLabel} href={service.href} />
        </div>

      </div>
    ))}
  </div>
</Section>
