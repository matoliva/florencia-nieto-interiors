---
import Section from './Section.astro';
import Heading from './Heading.astro';
import Body from './Body.astro';
import Button from './Button.astro';

interface Props {
  title: string;
  subtitle: string;
  service1Numeral: string;
  service1Title: string;
  service1Description: string;
  service1Href: string;
  service2Numeral: string;
  service2Title: string;
  service2Description: string;
  service2Href: string;
  service3Numeral: string;
  service3Title: string;
  service3Description: string;
  service3Href: string;
  knowMoreLabel: string;
}

const {
  title, subtitle,
  service1Numeral, service1Title, service1Description, service1Href,
  service2Numeral, service2Title, service2Description, service2Href,
  service3Numeral, service3Title, service3Description, service3Href,
  knowMoreLabel,
} = Astro.props;

const services = [
  { numeral: service1Numeral, title: service1Title, description: service1Description, href: service1Href },
  { numeral: service2Numeral, title: service2Title, description: service2Description, href: service2Href },
  { numeral: service3Numeral, title: service3Title, description: service3Description, href: service3Href },
];
---

<Section id="services" title={title} subtitle={subtitle}>
  <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border-default">
    {services.map((service, i) => (
      <div class:list={[
        'flex flex-col py-10 md:py-0',
        i === 0 ? 'md:pr-12 lg:pr-16' : i === 1 ? 'md:px-12 lg:px-16' : 'md:pl-12 lg:pl-16',
      ]}>

        <!-- Abstract thumbnail -->
        <div class="h-48 md:h-44 lg:h-52 mb-8 bg-surface-secondary overflow-hidden flex items-center justify-center">
          {i === 0 && (
            <!-- Floor plan: horizontal + vertical lines forming room geometry -->
            <svg viewBox="0 0 280 210" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
              <rect width="280" height="210" fill="var(--color-surface-secondary)" />
              <!-- outer frame -->
              <rect x="36" y="30" width="208" height="150" fill="none" stroke="var(--color-border-default)" stroke-width="1.2" />
              <!-- inner room division: vertical -->
              <line x1="140" y1="30" x2="140" y2="120" stroke="var(--color-border-default)" stroke-width="1" />
              <!-- inner room division: horizontal -->
              <line x1="36" y1="120" x2="244" y2="120" stroke="var(--color-border-default)" stroke-width="1" />
              <!-- door arc left room -->
              <path d="M 80 120 A 28 28 0 0 0 80 92" fill="none" stroke="var(--color-border-default)" stroke-width="0.9" stroke-dasharray="3 2" />
              <!-- door arc right room -->
              <path d="M 180 120 A 24 24 0 0 0 204 120" fill="none" stroke="var(--color-border-default)" stroke-width="0.9" stroke-dasharray="3 2" />
              <!-- window marks top -->
              <line x1="90" y1="30" x2="120" y2="30" stroke="var(--color-border-default)" stroke-width="2.5" />
              <line x1="158" y1="30" x2="196" y2="30" stroke="var(--color-border-default)" stroke-width="2.5" />
            </svg>
          )}
          {i === 1 && (
            <!-- E-Design: layered documents / screen composition -->
            <svg viewBox="0 0 280 210" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
              <rect width="280" height="210" fill="var(--color-surface-secondary)" />
              <!-- back layer -->
              <rect x="66" y="42" width="168" height="126" rx="2" fill="none" stroke="var(--color-border-subtle)" stroke-width="1" />
              <!-- mid layer, offset -->
              <rect x="52" y="54" width="168" height="126" rx="2" fill="var(--color-surface-primary)" stroke="var(--color-border-default)" stroke-width="1" opacity="0.85" />
              <!-- front layer -->
              <rect x="38" y="38" width="168" height="126" rx="2" fill="var(--color-surface-primary)" stroke="var(--color-border-default)" stroke-width="1.2" />
              <!-- content lines on front layer -->
              <line x1="56" y1="68" x2="176" y2="68" stroke="var(--color-border-default)" stroke-width="0.8" />
              <line x1="56" y1="82" x2="148" y2="82" stroke="var(--color-border-default)" stroke-width="0.8" />
              <line x1="56" y1="100" x2="176" y2="100" stroke="var(--color-border-default)" stroke-width="0.8" />
              <line x1="56" y1="114" x2="130" y2="114" stroke="var(--color-border-default)" stroke-width="0.8" />
              <line x1="56" y1="132" x2="176" y2="132" stroke="var(--color-border-default)" stroke-width="0.8" />
              <line x1="56" y1="146" x2="160" y2="146" stroke="var(--color-border-default)" stroke-width="0.8" />
            </svg>
          )}
          {i === 2 && (
            <!-- Consultation: single focal arc + dot, minimalist -->
            <svg viewBox="0 0 280 210" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
              <rect width="280" height="210" fill="var(--color-surface-secondary)" />
              <!-- outer arc -->
              <path d="M 80 168 A 96 96 0 0 1 200 168" fill="none" stroke="var(--color-border-default)" stroke-width="1" />
              <!-- mid arc -->
              <path d="M 100 168 A 64 64 0 0 1 180 168" fill="none" stroke="var(--color-border-default)" stroke-width="1" />
              <!-- inner arc -->
              <path d="M 120 168 A 32 32 0 0 1 160 168" fill="none" stroke="var(--color-border-default)" stroke-width="1" />
              <!-- focal vertical -->
              <line x1="140" y1="72" x2="140" y2="168" stroke="var(--color-border-default)" stroke-width="0.9" stroke-dasharray="4 3" />
              <!-- focal dot -->
              <circle cx="140" cy="72" r="4" fill="none" stroke="var(--color-border-default)" stroke-width="1.2" />
            </svg>
          )}
        </div>

        <!-- Service numeral -->
        <p class="font-body uppercase tracking-widest text-xs text-accent-gold mb-5">
          {service.numeral}
        </p>

        <!-- Service title -->
        <Heading variant="h2" class="mb-6">{service.title}</Heading>

        <!-- Description -->
        <Body class="text-text-secondary flex-1 mb-10">{service.description}</Body>

        <!-- Know More button -->
        <div class="pb-8 md:pb-0">
          <Button variant="arrow" label={knowMoreLabel} href={service.href} />
        </div>

      </div>
    ))}
  </div>
</Section>
