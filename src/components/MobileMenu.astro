---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, getActiveRouteChecker } from '../i18n/utils';
import ExternalLink from './ExternalLink.astro';
import FooterCredit from './FooterCredit.astro';
import Logo from './Logo.astro';
import { getTextureImage, textureStyle } from '../utils/texture';
import { navLinks, socialLinks } from '../config/nav';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const { pathname } = Astro.url;
const isActive = getActiveRouteChecker(pathname);
const buildHref = (route: string) => {
  const [path, hash] = route.split('#');
  return getRelativeLocaleUrl(locale, path || '/') + (hash ? `#${hash}` : '');
};

const texture = await getTextureImage(1318);
---

<div
  id="mobile-menu"
  class="texture-overlay-strong hidden fixed inset-0 z-50"
  style={textureStyle(texture.src)}
>
  <div class="relative z-10 flex flex-col items-center h-full overflow-y-auto px-8 pb-10">
    <div class="w-full flex justify-end pt-6">
      <button
        id="mobile-menu-close"
        type="button"
        aria-label="Close menu"
        class="p-1 text-text-primary"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="3" x2="19" y2="19" />
          <line x1="19" y1="3" x2="3" y2="19" />
        </svg>
      </button>
    </div>

    <Logo locale={locale} width={180} />

    <nav class="mt-8 flex flex-col items-center gap-6" aria-label="Mobile navigation">
      {navLinks.map(({ key, route }) => (
        <a
          href={buildHref(route)}
          class:list={[
            'font-body uppercase tracking-widest text-menu-nav transition-colors duration-200',
            isActive(route) ? 'text-accent-gold' : 'text-text-primary hover:text-accent-gold',
          ]}
        >
          {t(key)}
        </a>
      ))}
    </nav>

    <div class="menu-social-footer mt-auto w-full pt-8 border-t border-border-subtle flex flex-col items-center gap-10">
      <div class="flex flex-col items-center gap-5">
        {socialLinks.map(({ key, href }) => (
          <ExternalLink label={t(key)} href={href} />
        ))}
      </div>
      <FooterCredit class="items-center text-center" />
    </div>
  </div>
</div>

<style>
  /* Override ExternalLink's hardcoded text-sm — :global() escapes Astro's style scope */
  :global(.menu-social-footer a),
  :global(.menu-social-footer .footer-credit) {
    font-size: var(--font-size-menu-footer);
  }
</style>
