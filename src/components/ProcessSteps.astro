---
import Heading from './Heading.astro';
import Body from './Body.astro';

interface Props {
  steps: Array<{ title: string; desc: string }>;
}

const { steps } = Astro.props;
---

<div class="divide-y divide-border-default">
  {steps.map((step, i) => (
    <div class="py-10 md:py-12 flex flex-col md:flex-row md:gap-16 lg:gap-24">
      <p class="font-body uppercase tracking-widest text-accent-gold text-xs mb-4 md:mb-0 md:w-10 md:flex-shrink-0 md:pt-2">
        {String(i + 1).padStart(2, '0')}
      </p>
      <div class="flex-1">
        <Heading variant="h2" as="h3" class="mb-4">{step.title}</Heading>
        <Body class="text-text-secondary">{step.desc}</Body>
      </div>
    </div>
  ))}
</div>
