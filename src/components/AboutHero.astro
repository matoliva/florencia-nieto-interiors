---
import { Image } from 'astro:assets';
import Heading from './Heading.astro';
import aboutImg from '../assets/images/about.webp';

interface Props {
  name: string;
  subtitle: string;
}

const { name, subtitle } = Astro.props;
---

<section class="px-8 md:px-16 lg:px-24 py-10 md:py-14">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
    <div class="text-center md:text-left">
      <Heading variant="h1" class="text-center">{name}</Heading>
      <p class="font-signature text-3xl text-center text-text-primary mt-4">{subtitle}</p>
    </div>
    <div class="overflow-hidden rounded-t-[9999px] max-w-xs md:max-w-sm mx-auto">
      <Image
        src={aboutImg}
        alt={name}
        class="w-full h-auto"
        loading="eager"
      />
    </div>
  </div>
</section>
