---
interface Props {
  label: string;
  name: string;
  id?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  class?: string;
}

const { label, name, id, placeholder, rows = 4, required = false, class: className } = Astro.props;
type P = Props;
const inputId = (id ?? name) as P['id'];
---

<div class:list={['flex flex-col gap-2 w-full', className]}>
  <label for={inputId} class="form-label">
    {label}{required && <span class="text-accent-gold ml-1">*</span>}
  </label>
  <textarea
    id={inputId}
    name={name}
    placeholder={placeholder}
    rows={rows}
    required={required || undefined}
    class="form-field py-3 resize-none"
  ></textarea>
</div>
